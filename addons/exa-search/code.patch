+  private async resolveExaSearch(reply: string, messages: ChatMessage[], chatId: number | string): Promise<string> {
+    const marker = parseExaSearchMarker(reply);
+    if (!marker.query) return reply;
+    try {
+      const results = await runExaSearch(marker.query);
+      this.emit("event", { type: "info", text: `Exa search: ${marker.query} (${results.length})`, chatId } as RuntimeEvent);
+      const grounded = await this.llm.chat([
+        ...messages,
+        { role: "assistant", content: marker.cleanedReply || "[внутренний черновик перед web-поиском]" },
+        {
+          role: "system",
+          content: `# РЕЗУЛЬТАТ ТИХОГО WEB-ПОИСКА EXA
+Запрос: ${marker.query}
+
+${formatExaResults(results)}
+
+Ответь пользователю как живая девушка в Telegram, в стиле персоны. Не упоминай Exa, поиск, источники или "я нашла", если пользователь прямо не просил ссылку/источник. Если данных мало или они сомнительные — лучше ответь осторожно и коротко.`
+        }
+      ], { temperature: 0.85, maxTokens: 1200 });
+      return sanitizeModelReply(grounded) || marker.cleanedReply || reply;
+    } catch (e) {
+      this.emit("event", { type: "error", text: `Exa search failed: ${silentErrorLabel(e)}`, chatId } as RuntimeEvent);
+      return marker.cleanedReply || "не уверена";
+    }
+  }
