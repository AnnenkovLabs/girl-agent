{
  "name": "@thesashadev/manager-agent",
  "version": "0.5.0",
  "description": "AI-менеджер в Telegram: персональный секретарь с эскалацией боссу. Форк @thesashadev/girl-agent.",
  "type": "module",
  "bin": {
    "manager-agent": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:webui",
    "build:server": "tsup",
    "build:termux": "npm run build:server -- --env.NODE_OPTIONS=--max-old-space-size=384 && cd webui && npm install --silent --no-audit --no-fund && npm run build -- --minify=false",
    "build:webui": "cd webui && npm install --silent --no-audit --no-fund && npm run build",
    "dev": "tsx src/cli.ts",
    "dev:webui": "cd webui && npm run dev",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "author": "TheSashaDev (void)",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shxpe0x/girl-agent-manager.git"
  },
  "homepage": "https://github.com/shxpe0x/girl-agent-manager#readme",
  "bugs": {
    "url": "https://github.com/shxpe0x/girl-agent-manager/issues"
  },
  "keywords": [
    "telegram",
    "ai",
    "agent",
    "manager",
    "secretary",
    "webui",
    "mcp",
    "userbot",
    "llm",
    "anthropic",
    "openai"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "grammy": "^1.30.0",
    "input": "^1.0.1",
    "mri": "^1.2.0",
    "openai": "^4.77.0",
    "telegram": "^2.26.16",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "fast-check": "^3.23.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ip-address": "^10.2.0"
  }
}
